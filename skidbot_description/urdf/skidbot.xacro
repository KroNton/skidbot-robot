<?xml version="1.0" encoding="utf-8"?>

<robot name="ELM4-Chassis" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:include filename="$(find skidbot_description)/urdf/skidbot.gazebo" />
    <xacro:include filename="$(find skidbot_description)/urdf/skidbot_ros2_control.xacro" />


  <link name="base_footprint"/>

  <joint name="footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 0.154" rpy="0 0 0"/>
  </joint>


  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="18.71"/>
      <inertia ixx="0.3986" ixy="0"      ixz="0"
               iyy="1.092"  iyz="0"
               izz="1.337"/>
    </inertial>


    <collision>
      <origin xyz="0 0 0.0875" rpy="0 0 0"/>
      <geometry>
        <box size="0.8 0.389 0.171"/>
      </geometry>
    </collision>


    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://skidbot_description/meshes/BaseMetal.dae" scale="1 1 1"/>
      </geometry>
    </visual>


    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://skidbot_description/meshes/BaseRubber.dae" scale="1 1 1"/>
      </geometry>
    </visual>


    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://skidbot_description/meshes/BasePlastic.dae" scale="1 1 1"/>
      </geometry>
    </visual>


    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://skidbot_description/meshes/BaseClear.dae" scale="1 1 1"/>
      </geometry>
      <material name="clear_guard">
        <color rgba="0.6 0.6 0.7 0.5"/>
      </material>
    </visual>
  </link>


  <link name="front_left_arm">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.16"/>
      <inertia ixx="0.006274" ixy="0.002744" ixz="0"
               iyy="0.007678" iyz="0"
               izz="0.009408"/>
    </inertial>
    <collision>
      <origin xyz="0.055 0 -0.0305" rpy="0 0.505 0"/>
      <geometry>
        <box size="0.21 0.075 0.038"/>
      </geometry>
    </collision>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://skidbot_description/meshes/ArmLeftMetal.dae" scale="1 1 1"/>
      </geometry>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://skidbot_description/meshes/ArmLeftPlastic.dae" scale="1 1 1"/>
      </geometry>
    </visual>
  </link>


  <joint name="front_left_arm_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="front_left_arm"/>
    <origin xyz="0.263 0.238 0.029" rpy="0 0 0"/>
  </joint>


  <link name="front_left_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="3.854"/>
      <inertia ixx="0.009002" ixy="0.0006021" ixz="0"
               iyy="0.01313"  iyz="0"
               izz="0.009003"/>
    </inertial>

    <collision>
      <origin xyz="0 0 0" rpy="1.5707963267948966 0 0"/>
      <geometry>
        <cylinder radius="0.108" length="0.06"/>
      </geometry>
    </collision>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 3.14159265359"/>
      <geometry>
        <mesh filename="package://skidbot_description/meshes/HubMotor.dae" scale="1 1 1"/>
      </geometry>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 3.14159265359"/>
      <geometry>
        <mesh filename="package://skidbot_description/meshes/RubberWheel.dae" scale="1 1 1"/>
      </geometry>
    </visual>
  </link>


  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="front_left_arm"/>
    <child  link="front_left_wheel"/>
    <origin xyz="0.11861 0.095 -0.07453" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>


  <link name="rear_right_arm">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.16"/>
      <inertia ixx="0.006274" ixy="0.002744" ixz="0"
