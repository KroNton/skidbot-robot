    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://skidbot_description/meshes/RubberWheel.dae" scale="1 1 1"/>
      </geometry>
    </visual>
  </link>


  <joint name="rear_right_wheel_joint" type="continuous">
    <parent link="rear_right_arm"/>
    <child  link="rear_right_wheel"/>
    <origin xyz="0.11861 0.095 -0.07453" rpy="0 0 3.14159265359"/>
    <axis xyz="0 1 0"/>
  </joint>


  <link name="front_right_arm">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.16"/>
      <inertia ixx="0.006274" ixy="0.002744" ixz="0"
               iyy="0.007678" iyz="0"
