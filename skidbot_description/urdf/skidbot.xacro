    <child  link="front_right_wheel"/>
    <origin xyz="0.11861 -0.095 -0.07453" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>


  <link name="rear_left_arm">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.16"/>
      <inertia ixx="0.006274" ixy="0.002744" ixz="0"
