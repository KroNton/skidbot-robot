  <joint name="rear_right_arm_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="rear_right_arm"/>
    <origin xyz="-0.263 -0.238 0.029" rpy="0 0 3.14159265359"/>
  </joint>


  <link name="rear_right_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="3.854"/>
      <inertia ixx="0.009002" ixy="0.0006021" ixz="0"
               iyy="0.01313"  iyz="0"
               izz="0.009003"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707963267948966 0 0"/>
      <geometry>
        <cylinder radius="0.108" length="0.06"/>
      </geometry>
    </collision>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://skidbot_description/meshes/HubMotor.dae" scale="1 1 1"/>
