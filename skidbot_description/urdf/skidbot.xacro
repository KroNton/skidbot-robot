    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="0 -0.017 0"/>
      <geometry>
        <mesh filename="package://skidbot_description/meshes/ArmRightPlastic.dae" scale="1 1 1"/>
      </geometry>
    </visual>
  </link>


  <joint name="front_right_arm_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="front_right_arm"/>
    <origin xyz="0.263 -0.238 0.029" rpy="0 0 0"/>
  </joint>


  <link name="front_right_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="3.854"/>
      <inertia ixx="0.009002" ixy="0.0006021" ixz="0"
               iyy="0.01313"  iyz="0"
